{
  "name": "lesson-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3501",
    "build": "next build",
    "postbuild": "next-sitemap",
    "start": "next start",
    "lint": "npx eslint --fix \"src/**/*.{ts,tsx,js,jsx}\"",
    "pretest": "node tests/setup/pretest.mjs",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "analyze": "ANALYZE=true next build",
    "analyze:server": "ANALYZE=true BUNDLE_ANALYZE=server next build",
    "analyze:browser": "ANALYZE=true BUNDLE_ANALYZE=browser next build",
    "postinstall": "copyfiles -a -f node_modules/@churchapps/apphelper/dist/public/locales/** public/apphelper/locales && copyfiles -a -f node_modules/@churchapps/apphelper/dist/public/css/** public/apphelper/css"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@churchapps/apphelper": "0.7.17",
    "@churchapps/helpers": "1.4.1",
    "@emotion/cache": "^11.14.0",
    "@mui/icons-material": "^7.3.11",
    "@mui/lab": "^7.0.1-beta.25",
    "@mui/material": "^7.3.11",
    "@mui/material-nextjs": "^9.0.1",
    "@oramacloud/client": "^2.1.4",
    "@sentry/nextjs": "^10.52.0",
    "@stripe/react-stripe-js": "^3.10.0",
    "@stripe/stripe-js": "^7.9.0",
    "@types/react-dom": "^19.2.3",
    "axios": "^1.16.0",
    "cropperjs": "^1.6.2",
    "date-fns": "^4.1.0",
    "next": "^16.2.6",
    "next-sitemap": "^4.2.3",
    "react": "^19.2.6",
    "react-activity": "^2.1.3",
    "react-cookie": "^8.1.2",
    "react-cropper": "^2.3.3",
    "react-dom": "^19.2.6",
    "react-ga4": "^3.0.1",
    "react-hook-form": "^7.75.0",
    "react-lite-youtube-embed": "^3.5.1",
    "react-router-dom": "^7.15.0",
    "react-simple-maps": "^4.0.0-beta.6",
    "react-to-print": "^3.3.0",
    "react-tooltip": "^6.0.2",
    "react-vimeo": "^2.0.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.6",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-simple-maps": "^3.0.6",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "copyfiles": "^2.4.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "typescript": "^5.9.3"
  }
