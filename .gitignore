# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

*.bat
/public/content
/public/robots.txt
/public/sitemap*
/analyze
.serena
/test-results

/tests/.auth*

# dependencies
/node_modules
/.pnp
.pnp.js

# Yarn Berry (Corepack-managed, node-modules linker + global cache)
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
.pnp.*
# npm is blocked (preinstall guard); never commit an npm lockfile
package-lock.json

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env.development.local
.env.test.local
.env.production.local

# vercel
.vercel

# serverless
.serverless
.serverless_nextjs

.idea
# Sentry Config File
.env.sentry-build-plugin
Notes.md
.env
