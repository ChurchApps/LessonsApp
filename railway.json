{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "yarn postinstall && yarn build"
  },
  "deploy": {
    "startCommand": "yarn start",
    "healthcheckPath": "/",
    "healthcheckTimeout": 60,
    "restartPolicyType": "on_failure"
  }
}
